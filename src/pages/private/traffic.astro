---
import "../../styles/global.css";
import {
  getClickEvents,
  getAnalyticsStorageLabel,
  getVisitEvents,
  isAnalyticsAuthorized,
  type ClickEvent,
  type VisitEvent,
} from "../../lib/analytics";

export const prerender = false;

const noIndexHeaders = {
  "cache-control": "private, no-store",
  "content-type": "text/plain; charset=utf-8",
  "x-robots-tag": "noindex, nofollow",
};

Astro.response.headers.set("cache-control", "private, no-store");
Astro.response.headers.set("x-robots-tag", "noindex, nofollow");

if (!isAnalyticsAuthorized(Astro.url, Astro.request)) {
  return new Response("Not found", {
    status: 404,
    headers: noIndexHeaders,
  });
}

const [visits, clicks] = await Promise.all([
  getVisitEvents(500),
  getClickEvents(500),
]);
const now = Date.now();
const oneDay = 24 * 60 * 60 * 1000;
const oneWeek = 7 * oneDay;
const configuredTimeZone = process.env.ANALYTICS_TIME_ZONE || "America/New_York";
const createFormatter = (timeZone: string) => {
  try {
    return new Intl.DateTimeFormat("en-US", {
      dateStyle: "short",
      timeStyle: "short",
      timeZone,
    });
  } catch {
    return new Intl.DateTimeFormat("en-US", {
      dateStyle: "short",
      timeStyle: "short",
      timeZone: "America/New_York",
    });
  }
};
const formatter = createFormatter(configuredTimeZone);
const dashboardTimeZone = formatter.resolvedOptions().timeZone;

const within = (event: { timestamp: string }, windowMs: number) =>
  now - new Date(event.timestamp).getTime() <= windowMs;

const countBy = <T extends unknown>(
  rows: T[],
  getKey: (row: T) => string,
  fallback = "Unknown",
) => {
  const counts = new Map<string, number>();

  for (const row of rows) {
    const key = getKey(row) || fallback;
    counts.set(key, (counts.get(key) || 0) + 1);
  }

  return [...counts.entries()]
    .sort((a, b) => b[1] - a[1])
    .slice(0, 10);
};

const formatLocation = (visit: VisitEvent) =>
  [visit.city, visit.region, visit.country].filter(Boolean).join(", ");

const formatClickLocation = (click: ClickEvent) =>
  [click.city, click.region, click.country].filter(Boolean).join(", ");

const last24 = visits.filter((visit) => within(visit, oneDay)).length;
const last7 = visits.filter((visit) => within(visit, oneWeek)).length;
const instagram = visits.filter((visit) => visit.source === "Instagram").length;
const last24Clicks = clicks.filter((click) => within(click, oneDay)).length;
const marmotClicks = clicks.filter(
  (click) => click.targetLabel === "Marmot Systems",
).length;
const truistClicks = clicks.filter(
  (click) => click.targetLabel === "Truist Bank",
).length;
const sources = countBy(visits, (visit) => visit.source);
const paths = countBy(visits, (visit) => visit.path);
const locations = countBy(visits, formatLocation, "Unknown");
const clickTargets = countBy(clicks, (click) => click.targetLabel);
const recent = visits.slice(0, 60);
const recentClicks = clicks.slice(0, 40);
const storageLabel = getAnalyticsStorageLabel();
const refreshHref = `${Astro.url.pathname}?key=${encodeURIComponent(
  Astro.url.searchParams.get("key") || "",
)}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Traffic</title>
  </head>
  <body class="traffic-page">
    <header class="traffic-header">
      <div>
        <p class="traffic-kicker">private</p>
        <h1>Traffic</h1>
      </div>
      <a href={refreshHref}>refresh</a>
    </header>

    <section class="traffic-metrics" aria-label="Traffic totals">
      <article>
        <span>Last 24h</span>
        <strong>{last24}</strong>
      </article>
      <article>
        <span>Last 7d</span>
        <strong>{last7}</strong>
      </article>
      <article>
        <span>Instagram</span>
        <strong>{instagram}</strong>
      </article>
      <article>
        <span>Total stored</span>
        <strong>{visits.length}</strong>
      </article>
      <article>
        <span>Last 24h clicks</span>
        <strong>{last24Clicks}</strong>
      </article>
      <article>
        <span>Marmot clicks</span>
        <strong>{marmotClicks}</strong>
      </article>
      <article>
        <span>Truist clicks</span>
        <strong>{truistClicks}</strong>
      </article>
    </section>

    <section class="traffic-meta">
      <span>Storage: {storageLabel}</span>
      <span>Times shown in {dashboardTimeZone}</span>
      <span>No cookies, IPs, postal codes, lat/long, or full user-agent strings stored</span>
    </section>

    <section class="traffic-grid">
      <div class="traffic-panel">
        <h2>Sources</h2>
        <table>
          <tbody>
            {sources.map(([source, count]) => (
              <tr>
                <th>{source}</th>
                <td>{count}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="traffic-panel">
        <h2>Pages</h2>
        <table>
          <tbody>
            {paths.map(([path, count]) => (
              <tr>
                <th>{path}</th>
                <td>{count}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="traffic-panel">
        <h2>Locations</h2>
        <table>
          <tbody>
            {locations.map(([location, count]) => (
              <tr>
                <th>{location}</th>
                <td>{count}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="traffic-panel">
        <h2>Tracked Clicks</h2>
        <table>
          <tbody>
            {clickTargets.map(([target, count]) => (
              <tr>
                <th>{target}</th>
                <td>{count}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="traffic-panel traffic-recent">
      <h2>Recent Link Clicks</h2>
      <table>
        <thead>
          <tr>
            <th>Time</th>
            <th>Link</th>
            <th>Page</th>
            <th>Device</th>
            <th>Browser</th>
            <th>Location</th>
          </tr>
        </thead>
        <tbody>
          {recentClicks.map((click) => (
            <tr>
              <td>{formatter.format(new Date(click.timestamp))}</td>
              <td>
                <span>{click.targetLabel}</span>
                <small>{click.linkText || click.targetHost}</small>
              </td>
              <td>{click.path}</td>
              <td>{click.device}</td>
              <td>{click.browser}</td>
              <td>{formatClickLocation(click) || "Unknown"}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="traffic-panel traffic-recent">
      <h2>Recent Visits</h2>
      <table>
        <thead>
          <tr>
            <th>Time</th>
            <th>Source</th>
            <th>Page</th>
            <th>Device</th>
            <th>Browser</th>
            <th>Location</th>
            <th>Locale</th>
          </tr>
        </thead>
        <tbody>
          {recent.map((visit) => (
            <tr>
              <td>{formatter.format(new Date(visit.timestamp))}</td>
              <td>
                <span>{visit.source}</span>
                {visit.sourceDetail && <small>{visit.sourceDetail}</small>}
              </td>
              <td>{visit.path}</td>
              <td>{visit.device}</td>
              <td>{visit.browser}</td>
              <td>{formatLocation(visit) || "Unknown"}</td>
              <td>
                <span>{visit.country || "Unknown"}</span>
                {visit.language && <small>{visit.language}</small>}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  </body>
</html>
